generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StudentMaster {
  id               String @id @default(cuid())
  enrollmentNumber String @unique
  name             String
  branch           String
  course           String
  batch            String
}

model AlumniMaster {
  id               String @id @default(cuid())
  enrollmentNumber String @unique
  name             String
  course           String
  branch           String
  batch            String
}

model Admin {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  role         String @default("admin")
}

model Student {
  id                           String              @id @default(cuid())
  name                         String
  enrollmentNumber             String              @unique
  email                        String              @unique
  branch                       String
  semester                     Int
  cgpa                         Float
  isEmailVerified              Boolean             @default(false)
  isVerified                   Boolean             @default(false)
  emailVerificationToken       String?
  emailVerificationTokenExpiry DateTime?
  resetPasswordToken           String?
  resetPasswordTokenExpiry     DateTime?
  profileImageUrl              String?
  resumeUrl                    String?
  memoriesImageUrl             String?
  feedback                     String?
  batch                        String
  phoneNumber                  String
  course                       String
  passwordHash                 String
  linkedinUrl                  String?
  githubUrl                    String?
  tenthPercentage                Float
  twelfthPercentage             Float
  activeBacklog                 Int                @default(0)
  role                         String              @default("student")
  registrations                DriveRegistration[]
  memories                     Memory[]
  studentFeedbacks             StudentFeedback[]
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
}

model Alumni {
  id                String           @id @default(cuid())
  name              String
  enrollmentNumber  String           @unique
  personalEmail     String           @unique
  passwordHash      String
  isVerified        Boolean          @default(false)
  emailVerificationToken       String?
  emailVerificationTokenExpiry DateTime?
  resetPasswordToken           String?
  resetPasswordTokenExpiry     DateTime?
  isProfileComplete Boolean          @default(false)
  currentCompany    String?
  profileImageUrl    String
  jobTitle          String?
  city              String?
  country           String?
  linkedInUrl       String?
  phoneNumber       String?
  privacyJson       Json?
  branch            String
  about             String?
  batch             String
  course            String
  referrals         Referral[]
  alumniFeedbacks   AlumniFeedback[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model ExternalStudent {
  id               String              @id @default(cuid())
  name             String
  collegeName      String
  enrollmentNumber String
  email            String              @unique
  passwordHash     String
  profileImageUrl  String
  feedback         String?
  semester         Int
  linkedinUrl      String?
  githubUrl        String?
  resumeUrl        String
  branch           String
  tenthPercentage    Float
  twelfthPercentage Float
  cgpa             Float
  activeBacklog     Int                 @default(0)
  course           String
  batch            String
  phoneNumber      String
  isVerified                   Boolean             @default(false)
  emailVerificationToken       String?
  emailVerificationTokenExpiry DateTime?
  resetPasswordToken           String?
  resetPasswordTokenExpiry     DateTime?
  role                         String              @default("external_student")
  registrations                DriveRegistration[]
}

// 4. DRIVE & INTERACTION MODELS
model PlacementDrive {
  id               String              @id @default(cuid())
  companyName      String
  roleName         String
  jobDescription   String
  ctc              String
  minCGPA          Float
  jobType           String
  minBatch         String
  maxBatch         String
  course           String
  eligibleBranches String
  driveDate        DateTime
  driveType        String
  status           String              @default("pending")
  googleSheetUrl   String?
  recruiterId      String
  recruiter        Recruiter           @relation(fields: [recruiterId], references: [id])
  registrations    DriveRegistration[]
}

model DriveRegistration {
  id      String         @id @default(cuid())
  driveId String
  drive   PlacementDrive @relation(fields: [driveId], references: [id])

  studentId         String?
  student           Student?         @relation(fields: [studentId], references: [id])
  externalStudentId String?
  externalStudent   ExternalStudent? @relation(fields: [externalStudentId], references: [id])

  attended  Boolean  @default(false)
  status    String   @default("Applied")
  createdAt DateTime @default(now())
}

model Recruiter {
  id           String @id @default(cuid())
  name         String
  email        String @unique
  phoneNumber  String
  designation  String
  company      String
  passwordHash String
  role         String @default("recruiter")

  drives             PlacementDrive[]
  corporateFeedbacks CorporateFeedback[]
}

model Referral {
  id          String @id @default(cuid())
  companyName String
  position    String
  description String
  applyLink   String
  status      String @default("pending")
  alumniId    String
  alumni      Alumni @relation(fields: [alumniId], references: [id])
}

model Memory {
  id        String   @id @default(cuid())
  imageUrl  String
  status    String   @default("pending_moderation")
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  createdAt DateTime @default(now())
}

model AlumniFeedback {
  id       String @id @default(cuid())
  content  String
  rating   Int
  alumniId String
  alumni   Alumni @relation(fields: [alumniId], references: [id])
}

model StudentFeedback {
  id        String  @id @default(cuid())
  content   String
  rating    Int
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
}

model CorporateFeedback {
  id          String    @id @default(cuid())
  content     String
  rating      Int
  recruiterId String
  recruiter   Recruiter @relation(fields: [recruiterId], references: [id])
}
