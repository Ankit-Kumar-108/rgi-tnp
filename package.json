    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "^15.5.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "ts-morph": "^28.0.0",
    "typescript": "^5",
    "wrangler": "^4.96.0"
  }
